# .env.example — Salin file ini ke .env.local lalu isi nilainya

# ── Database (Neon.tech PostgreSQL)
# Dapatkan dari: https://neon.tech → project → connection string
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/socialqueue?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/socialqueue?sslmode=require"

# ── NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
# Generate: openssl rand -base64 32

# ── Encryption Key untuk credentials & session cookies
TOKEN_ENCRYPTION_KEY=""
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Google Gemini AI
# Dapatkan dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── Cron secret (untuk melindungi endpoint /api/cron/process-queue)
CRON_SECRET=""
# Generate: openssl rand -hex 32

# ── Opsional: Upstash QStash (jika tidak menggunakan worker mandiri)
